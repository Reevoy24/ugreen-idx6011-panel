# ug-fand — fan control for the UGREEN iDX6011 Pro
#
# mode: silent | default | turbo
mode=default
#
# polling / update interval in seconds (1..60)
interval=3
#
# force=1 runs even if the DMI product name is not an iDX6011 (NOT recommended —
# the EC fan registers are specific to this model).
#force=1
#
# Fan curves (optional, hot-reloaded on save). Each value is a comma-separated
# list of  temp:duty  points (temp in C, duty 0..198). cpu_* curves follow the
# CPU temperature, sys_* curves the disk/NVMe temperature. Omit a line to keep
# the built-in default shown here. Higher duty = faster + louder.
#cpu_silent=0:18,64:18,74:70,82:140,88:198
#cpu_default=0:24,60:24,70:75,78:140,86:198
#cpu_turbo=0:50,55:50,66:130,75:185,82:198
#sys_silent=0:40,49:40,53:95,57:160,60:198
#sys_default=0:55,48:55,52:110,56:170,60:198
#sys_turbo=0:95,47:95,51:150,55:190,58:198
