# ug-fand — fan control for the UGREEN iDX6011 Pro.
# All settings are hot-reloaded on save (no restart needed).

# Active mode: silent | default | turbo
mode=default

# Polling / update interval in seconds (1..60)
interval=3

# Run even if the DMI product name is not an iDX6011 (NOT recommended — the EC
# fan registers are specific to this model). Uncomment to force.
#force=1

# Fan curves: comma-separated  TEMP:SPEED  points — TEMP in degrees C, SPEED in
# percent (0-100; 100 = full speed). The speed is interpolated between points
# and held flat below the first / above the last point. cpu_* curves follow the
# CPU temperature, sys_* the disk/NVMe temperature. Edit these freely; delete a
# line to fall back to the built-in default.
cpu_silent=0:9,64:9,74:35,82:71,88:100
cpu_default=0:12,60:12,70:38,78:71,86:100
cpu_turbo=0:25,55:25,66:66,75:93,82:100
sys_silent=0:20,49:20,53:48,57:81,60:100
sys_default=0:28,48:28,52:56,56:86,60:100
sys_turbo=0:48,47:48,51:76,55:96,58:100

# Safety: above 88 C (CPU) or 60 C (disks) the fans go to 100% regardless.
