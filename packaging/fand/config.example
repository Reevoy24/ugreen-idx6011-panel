# ug-fand — fan control for the UGREEN iDX6011 (Pro and non-Pro).
# The daemon auto-detects the model by DMI:
#   * iDX6011 Pro      -> 4 fans (CPU + system), EC offsets 0x34 / 0xB0
#   * iDX6011 non-Pro  -> 2 system fans (no separate CPU fan), EC 0x96 / 0x9C
# On the non-Pro the two system fans also cool the CPU, so they are driven by
# whichever curve (cpu_* vs sys_*) demands more at the current temperatures.
# All settings are hot-reloaded on save (no restart needed).

# Active mode: silent | default | turbo
mode=default

# Polling / update interval in seconds (1..60)
interval=3

# Run even if the DMI product name is not an iDX6011 (NOT recommended —
# the EC fan registers are specific to these models). Uncomment to force.
#force=1

# Fan curves: comma-separated  TEMP:SPEED  points — TEMP in degrees C, SPEED in
# percent (0-100; 100 = full speed). The speed is interpolated between points
# and held flat below the first / above the last point. cpu_* curves follow the
# CPU temperature, sys_* the disk/NVMe temperature. Edit these freely; delete a
# line to fall back to the built-in default.
cpu_silent=0:14,64:14,74:35,82:71,88:100
cpu_default=0:15,60:15,70:38,78:71,86:100
cpu_turbo=0:25,55:25,66:66,75:93,82:100
sys_silent=0:20,54:20,60:45,64:75,68:100
sys_default=0:28,52:28,58:55,63:80,68:100
sys_turbo=0:48,47:48,51:76,55:96,58:100

# Safety: above 88 C (CPU) or 68 C (disks) the fans go to 100% regardless.
